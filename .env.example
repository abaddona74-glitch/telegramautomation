# ===============================================
# TELEGRAM AGENT - NAMONAVIY SOZLAMALAR FAYLI
# Ushbu faylni nomini ".env" deb o'zgartiring va 
# o'zingizning aniq kalitlaringizni kiriting!
# ===============================================

# 1. my.telegram.org saytiga kirib olingan API ma'lumotlari:
TELEGRAM_API_ID=SIZNING_API_RAQAMINGIZ_SHU_ERGA
TELEGRAM_API_HASH=SIZNING_HASH_KODINGIZ_SHU_ERGA
TELEGRAM_SESSION_NAME=my_agent_session

# 2. Google Cloud dagi JSON faylingiz nomi (bu doim secrets papkasida turishi kerak)
GOOGLE_SERVICE_ACCOUNT_FILE=secrets/mysupporttbot-57b27007f0c3.json

# 3. Google Sheet faylingizning o'qilishi kerak bo'lgan URL manzili:
GOOGLE_SHEET_URL=https://docs.google.com/spreadsheets/d/SIZNING_SHEET_ID_RAQAMINGIZ/edit

# -- QOLGAN SOZLAMALAR (TEGINMANG) --
CONTACTS_SHEET=contacts
TEMPLATES_SHEET=templates
SETTINGS_SHEET=settings
TIMEZONE=Asia/Tashkent
SQLITE_PATH=runtime/state.db
POLL_INTERVAL_SECONDS=10
LOG_LEVEL=INFO
ENABLE_TELEGRAM_CONTROL=true
ENABLE_AUTO_GRID_FORMAT=true
AUTO_GRID_CHECK_EVERY_CYCLES=6
ENABLE_CONTACTS_COMPACT=true
